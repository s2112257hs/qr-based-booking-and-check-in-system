generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  receptionist
  staff_scanner
}

enum BookingStatus {
  ACTIVE
  CANCELLED
  CHECKED_IN
}

enum CheckinResult {
  VALID
  INVALID
}

enum boatName {
  W_speed
  Hiriwave
  Small_speed
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  username          String?   @unique
  password_hash     String?
  role              UserRole
  is_active         Boolean   @default(true)
  createdTrips      Trip[]    @relation("TripCreator")
  createdBookings   Booking[] @relation("BookingCreator")
  cancelledBookings Booking[] @relation("BookingCanceller")
  scanAttempts      Checkin[] @relation("Scanner")
}

model Trip {
  id                  String    @id @default(uuid()) @db.Uuid
  date                DateTime  @db.Date
  start_time          DateTime  @db.Time(6)
  boat                boatName
  max_capacity        Int
  created_by_user_id  String    @db.Uuid
  created_at          DateTime  @default(now())

  createdBy           User      @relation("TripCreator", fields: [created_by_user_id], references: [id])
  activityTypes       TripActivityType[]
  bookings            Booking[]
  checkinsByTrip      Checkin[] @relation("CheckinTrip")
  checkinsBySelection Checkin[] @relation("CheckinSelectedTrip")
}

model ActivityType {
  id    String             @id @default(uuid()) @db.Uuid
  code  String             @unique
  name  String             @unique
  trips TripActivityType[]
}

model TripActivityType {
  trip_id          String       @db.Uuid
  activity_type_id String       @db.Uuid

  trip             Trip         @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  activityType     ActivityType @relation(fields: [activity_type_id], references: [id], onDelete: Cascade)

  @@id([trip_id, activity_type_id])
  @@index([activity_type_id])
}

model Booking {
  id                   String        @id @default(uuid()) @db.Uuid
  trip_id              String        @db.Uuid
  guest_name           String
  adult_pax_count      Int
  children_pax_count   Int
  inhouse              Boolean
  guesthouse_name      String
  status               BookingStatus @default(ACTIVE)
  created_by_user_id   String        @db.Uuid
  created_at           DateTime      @default(now())
  cancelled_by_user_id String?       @db.Uuid
  cancelled_at         DateTime?

  trip                 Trip          @relation(fields: [trip_id], references: [id])
  createdBy            User          @relation("BookingCreator", fields: [created_by_user_id], references: [id])
  cancelledBy          User?         @relation("BookingCanceller", fields: [cancelled_by_user_id], references: [id])
  ticket               Ticket?
  checkins             Checkin[]
}

model Ticket {
  booking_id String   @id @db.Uuid
  token_hash String   @unique
  issued_at  DateTime @default(now())

  booking    Booking  @relation(fields: [booking_id], references: [id])
}

model Checkin {
  id                 String       @id @default(uuid()) @db.Uuid
  booking_id         String       @db.Uuid
  trip_id            String       @db.Uuid
  selected_trip_id   String       @db.Uuid
  scanned_by_user_id String       @db.Uuid
  scanned_at         DateTime     @default(now())
  result             CheckinResult
  reason             String

  booking            Booking      @relation(fields: [booking_id], references: [id])
  trip               Trip         @relation("CheckinTrip", fields: [trip_id], references: [id])
  selectedTrip       Trip         @relation("CheckinSelectedTrip", fields: [selected_trip_id], references: [id])
  scannedBy          User         @relation("Scanner", fields: [scanned_by_user_id], references: [id])

  @@index([booking_id])
  @@index([selected_trip_id])
}
